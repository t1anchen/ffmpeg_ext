# enforce to keep the eol in workspace same as the eol in git repository
* text eol=lf

# spec
# https://datatracker.ietf.org/doc/html/rfc4180#section-2
*.csv          text eol=crlf
# https://datatracker.ietf.org/doc/html/rfc6350#section-3.2
*.vcf          text eol=crlf
*.org          text eol=lf
*.org_archive  text eol=lf
*.json         text
*.toml         text eol=lf
*.xml          text
*.yaml         text
*.yml          text
# Text files where line endings should be preserved
*.patch    -text
*.diff     -text
# Exclude files from exporting
.gitattributes export-ignore
.gitignore     export-ignore
.gitkeep       export-ignore

# posix
*.bash     text eol=lf
*.fish     text eol=lf
*.ksh      text eol=lf
*.sh       text eol=lf
*.zsh      text eol=lf

# windows
*.cmd               text eol=crlf
AppData/**/*.Config text eol=crlf
*.bat               text eol=crlf
*.proj              text eol=crlf
*.props             text eol=crlf
*.ps1               text eol=crlf
*.sln               text eol=crlf
*.vcxproj*          text eol=crlf
*.exe               binary

